extends ../layout/default.pug

block content
    .chat-app.d-flex

        //- Sidebar
        include ../partial/sidebar.pug

        //- Main chat
        .chat-main.flex-grow-1.d-flex.flex-column

            //- Header
            .chat-header.d-flex.justify-content-between.align-items-center
                .d-flex.align-items-center
                    img.avatar(src="https://i.pravatar.cc/40")
                .ms-2
                    .name Hội Bạn Thân ❤️
                    .status.text-success Đang hoạt động

                .actions
                    button.btn.btn-dark.btn-sm.me-2 📞
                    button.btn.btn-dark.btn-sm.me-2 🎥
                    button.btn.btn-dark.btn-sm ℹ️

            //- Body chat
            .chat-body.flex-grow-1
                .message.left
                    span Xin chào! 👋
                .message.right
                    span Chào bạn!

            //- Input
            .chat-input
                .d-flex.align-items-center
                    button.btn.btn-dark.me-2 ➕
                    input.form-control(type="text" placeholder="Aa")
                    button.btn.btn-dark.ms-2 😊
                    button.btn.btn-primary.ms-2 👍